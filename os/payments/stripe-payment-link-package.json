        { "lookupKey": "avalon_supporter_annual", "amountUsd": 50.00, "interval": "year" }
      ],
      "paymentLink": {
        "placeholderUrl": "STRIPE_PAYMENT_LINK_AVALON_SUPPORTER",
        "collect": ["name", "email"],
        "allowPromotionCodes": true,
        "allowDonationTopUps": true,
        "redirectUrl": "https://thelingolegacy.com/site/avalon/?activated=avalon-supporter",
        "enabledMethods": ["Apple Pay", "Google Pay", "Link", "Cards"]
      }
    },
    {
      "id": "prod_creator_partner_tier",
      "name": "Creator / Partner Tier",
      "type": "service",
      "mode": "subscription",
      "prices": [
        { "lookupKey": "creator_partner_monthly", "amountUsd": 14.99, "interval": "month" },
        { "lookupKey": "creator_partner_annual", "amountUsd": 149.00, "interval": "year" }
