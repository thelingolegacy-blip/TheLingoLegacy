  "platformConfiguration": {
    "applePayDomain": "thelingolegacy.com",
    "googlePay": "enable in Stripe Payment Methods",
    "stripeTax": "optional but recommended before global paid launch",
    "customerPortal": "enable for subscription self-service",
    "webhookEvents": [
      "checkout.session.completed",
      "customer.subscription.updated",
      "invoice.payment_failed",
      "customer.subscription.deleted"
    ]
  },
  "secretHandling": [
    "Do not commit Stripe secret keys.",
    "Use Payment Links first for static pages.",
    "Use webhooks only when fulfillment backend exists.",
    "Only public Payment Link URLs should be added to the repository."
  ]
}
