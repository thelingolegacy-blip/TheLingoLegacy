{
  "version": "1.0",
  "status": "ready-for-stripe-dashboard-creation",
  "architecture": "one product, multiple prices, one public Payment Link per tier or purchase group",
  "domain": "thelingolegacy.com",
  "products": [
    {
      "id": "prod_lingo_ai_premium",
      "name": "Lingo.ai Premium",
      "type": "service",
      "mode": "subscription",
      "prices": [
        { "lookupKey": "lingo_ai_premium_monthly", "amountUsd": 9.99, "interval": "month" },
        { "lookupKey": "lingo_ai_premium_annual", "amountUsd": 99.00, "interval": "year" }
      ],
      "paymentLink": {
        "placeholderUrl": "STRIPE_PAYMENT_LINK_LINGO_AI_PREMIUM",
        "collect": ["name", "email"],
        "allowPromotionCodes": true,
        "redirectUrl": "https://thelingolegacy.com/site/lingoai/?activated=lingo-ai-premium",
        "enabledMethods": ["Apple Pay", "Google Pay", "Link", "Cards"]
      }
    },
    {
      "id": "prod_lingo_os_builder",
      "name": "Lingo Legacy OS Builder",
      "type": "service",
      "mode": "subscription",
      "prices": [
        { "lookupKey": "lingo_os_builder_monthly", "amountUsd": 29.00, "interval": "month" },
        { "lookupKey": "lingo_os_builder_annual", "amountUsd": 290.00, "interval": "year" }
      ],
      "paymentLink": {
        "placeholderUrl": "STRIPE_PAYMENT_LINK_LINGO_OS_BUILDER",
        "collect": ["name", "email"],
        "allowPromotionCodes": true,
        "redirectUrl": "https://thelingolegacy.com/site/os/?activated=os-builder",
