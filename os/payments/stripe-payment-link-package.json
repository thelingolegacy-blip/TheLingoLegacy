    },
    {
      "id": "prod_xp_booster_crown_pack",
      "name": "XP Booster / Crown Pack",
      "type": "service",
      "mode": "payment",
      "prices": [
        { "lookupKey": "xp_booster_small", "amountUsd": 4.99 },
        { "lookupKey": "xp_booster_medium", "amountUsd": 9.99 },
        { "lookupKey": "xp_booster_large", "amountUsd": 19.99 },
        { "lookupKey": "crown_pack_premium", "amountUsd": 49.99 }
